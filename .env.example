# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (the bot will only respond to this user)
TELEGRAM_OWNER_CHAT_ID=your_chat_id_here

# Groq API key for Whisper STT (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Path to claude CLI binary (optional, auto-detected if in PATH)
# CLAUDE_PATH=/usr/local/bin/claude

# Default project key (optional)
# DEFAULT_PROJECT=example

# Voice response (on/off, optional)
# VOICE_RESPONSE=off

# Projects config as JSON (optional, overrides defaults in session.py)
# PROJECTS_JSON={"myproject": {"name": "My Project", "path": "/home/user/myproject"}}
